{
  "name": "@solncebro/exchange-engine",
  "version": "0.7.1",
  "description": "Universal TypeScript client library for Binance and Bybit with unified API, type safety, and WebSocket support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "yarn lint && rm -rf dist && tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:smoke": "ts-node --project test/tsconfig.json test/smoke.test.ts",
    "lint": "eslint src/ test/",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "yarn lint && yarn test && yarn build && yarn type-check"
  },
  "keywords": [
    "exchange",
    "binance",
    "bybit",
    "trading",
    "websocket",
    "rest",
    "crypto",
    "cryptocurrency",
    "api",
    "client",
    "typescript"
  ],
  "author": {
    "name": "solncebro",
    "url": "https://github.com/solncebro"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/solncebro/exchange-engine.git"
  },
  "bugs": {
    "url": "https://github.com/solncebro/exchange-engine/issues"
  },
  "homepage": "https://github.com/solncebro/exchange-engine#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@solncebro/websocket-engine": "^0.3.0",
    "agentkeepalive": "^4.6.0",
    "axios": "^1.7.7"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
